GEMINI_API_KEY=your_gemini_api_key_here
GROQ_API_KEY=your_groq_api_key_here
LITELLM_API_KEY=your_litellm_api_key_here
LITELLM_BASE_URL=https://litellm.tikalk.dev/v1
LITELLM_MODEL=kimi-k2.5
LLM_PROVIDER=litellm
# Sampling temperature. Leave UNSET for kimi-k2.5 (it only allows 1 and 400s
# otherwise). Set to 0 only on providers that support it (Gemini/Groq) for
# deterministic output.
LLM_TEMPERATURE=
FLASK_SECRET_KEY=change_me_in_production
FLASK_DEBUG=1

# Logfire tracing (optional). Without LOGFIRE_TOKEN, tracing is a no-op.
LOGFIRE_TOKEN=your_logfire_write_token_here
LOGFIRE_USER=your_logfire_username
# Set to 1 to trace ONLY agent calls (suppress Flask/orchestrator/raw-client spans).
LOGFIRE_AGENTS_ONLY=0
